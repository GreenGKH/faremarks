generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider  = "postgresql"
    url       = env("DATABASE_URL")
    directUrl = env("DIRECT_URL")
}

model Bookmark {
    id        String   @id @default(cuid())
    url       String
    title     String
    description String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
