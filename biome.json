{
    "$schema": "https://biomejs.dev/schemas/2.3.8/schema.json",
    "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
    "files": {
        "ignoreUnknown": false,
        "includes": [
            "**",
            "!**/pnpm-lock.yaml",
            "!**/next-env.d.ts",
            "!**/migrations/**/*",
            "!**/node_modules/**/*",
            "!**/.next",
            "!**/dist"
        ]
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineEnding": "lf",
        "lineWidth": 80
    },
    "linter": {
        "enabled": true,
        "domains": { "next": "recommended" },
        "rules": {
            "recommended": true,
            "style": {
                "useImportType": "on",
                "useExportType": "on",
                "useNodejsImportProtocol": "error",
                "useConst": "on",
                "noNonNullAssertion": "warn"
            },
            "nursery": {
                "useSortedClasses": {
                    "level": "on",
                    "fix": "safe",
                    "options": { "functions": ["cn", "twMerge", "cva"] }
                }
            },
            "suspicious": {
                "noExplicitAny": "error"
            }
        }
    },
    "javascript": {
        "formatter": {
            "jsxQuoteStyle": "double",
            "quoteStyle": "double",
            "semicolons": "asNeeded",
            "trailingCommas": "none",
            "arrowParentheses": "always"
        }
    },
    "assist": {
        "enabled": true,
        "actions": { "source": { "organizeImports": "on" } }
    },
    "css": {
        "parser": {
            "cssModules": false,
            "tailwindDirectives": true
        }
    }
}
